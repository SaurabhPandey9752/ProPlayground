{
  "name": "proxy-manager-extension",
  "version": "1.0.0",
  "description": "Chrome extension for HTTP/HTTPS proxy management",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build && npm run build:copy",
    "build:copy": "cp manifest.json dist/ && cp -r public/icons dist/ && [ -f dist/src/popup/index.html ] && mv dist/src/popup/index.html dist/popup.html && rm -rf dist/src && npm run build:fix-paths || true",
    "build:fix-paths": "sed -i 's|src=\"\\.\\./../|src=\"./|g' dist/popup.html && sed -i 's|href=\"\\.\\./../|href=\"./|g' dist/popup.html",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src/**/*.{ts,tsx,css}",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.251",
    "@types/node": "^24.3.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
